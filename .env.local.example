# Copy this file to ".env.local" and fill in the key, then restart the dev server.
#
# FITBOX custom-order email is sent via Web3Forms (https://web3forms.com) — a
# free, no-backend form API. Create an Access Key with the inbox that should
# receive orders (e.g. msaruloffcl@gmail.com) and paste it below.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key

# OPTIONAL — image hosting so design/preview images arrive as links in the
# order email (Web3Forms free plan can't attach files). Free key at
# https://api.imgbb.com
NEXT_PUBLIC_IMGBB_API_KEY=your-imgbb-api-key
